{
  "name": "control-pesaje-backend",
  "version": "1.0.0",
  "type": "module",
  "description": "Backend para el sistema de control de pesaje",
  "main": "dist/index.js",
  "scripts": {
    "test": "vitest",
    "build": "tsc",
    "start": "node dist/src/index.js",
    "seed": "ts-node-esm src/seed.ts",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
