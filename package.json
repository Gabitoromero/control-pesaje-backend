    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": [],
  "author": "RomeroSoft",
  "license": "ISC",
  "packageManager": "pnpm@10.33.0",
  "dependencies": {
    "@mikro-orm/core": "^7.1.1",
    "@mikro-orm/decorators": "^7.1.1",
    "@mikro-orm/migrations": "^7.1.1",
    "@mikro-orm/postgresql": "^7.1.1",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.2",
    "reflect-metadata": "^0.2.2",
    "socket.io": "^4.8.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@mikro-orm/cli": "^7.1.1",
    "@types/bcryptjs": "^3.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^25.9.1",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^8.59.4",
    "@typescript-eslint/parser": "^8.59.4",
    "@vitest/coverage-v8": "4.1.9",
    "eslint": "^10.4.0",
    "prettier": "^3.8.3",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7"
